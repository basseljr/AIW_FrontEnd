{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "newProjectRoot": "projects",
  "cli": {
    "schematicCollections": [
      "@angular-eslint/schematics"
    ],
    "analytics": false
  },
  "schematics": {
    "@angular-eslint/schematics:application": {
      "setParserOptionsProject": true
    },
    "@angular-eslint/schematics:library": {
      "setParserOptionsProject": true
    },
    "@schematics/angular:component": {
      "standalone": true,
      "style": "css",
      "changeDetection": "OnPush"
    }
  },
  "projects": {
    "storefront": {
      "projectType": "application",
      "schematics": {},
      "root": "projects/storefront",
      "sourceRoot": "projects/storefront/src",
      "prefix": "sf",
      "architect": {
        "build": {
          "builder": "@angular-devkit/build-angular:application",
          "options": {
            "outputPath": "dist/storefront",
            "index": "projects/storefront/src/index.html",
            "browser": "projects/storefront/src/main.ts",
            "server": "projects/storefront/src/main.server.ts",
            "ssr": {
              "entry": "projects/storefront/server.ts"
            },
            "polyfills": [
              "zone.js"
            ],
            "tsConfig": "projects/storefront/tsconfig.app.json",
            "assets": [
              {
                "glob": "**/*",
                "input": "projects/storefront/public"
              },
              {
                "glob": "**/*",
                "input": "projects/shared-i18n/src/lib/assets/i18n",
                "output": "/assets/i18n"
              }
            ],
            "styles": [
              "projects/storefront/src/styles.css",
              "node_modules/leaflet/dist/leaflet.css"
            ],
            "scripts": []
          },
          "configurations": {
            "production": {
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "1mb",
                  "maximumError": "2mb"
                },
                {
                  "type": "anyComponentStyle",
                  "maximumWarning": "10kb",
                  "maximumError": "20kb"
                }
              ],
              "allowedCommonJsDependencies": [
                "compression",
                "@microsoft/signalr",
                "leaflet"
              ],
              "fileReplacements": [
                {
                  "replace": "projects/storefront/src/environments/environment.ts",
                  "with": "projects/storefront/src/environments/environment.prod.ts"
                }
              ],
              "outputHashing": "all"
            },
            "development": {
              "optimization": false,
              "extractLicenses": false,
              "sourceMap": true
            }
          },
          "defaultConfiguration": "production"
        },
        "serve": {
          "builder": "@angular-devkit/build-angular:dev-server",
          "options": {
            "proxyConfig": "projects/storefront/proxy.conf.json"
          },
          "configurations": {
            "production": {
              "buildTarget": "storefront:build:production"
            },
            "development": {
              "buildTarget": "storefront:build:development"
            }
          },
          "defaultConfiguration": "development"
        },
        "extract-i18n": {
          "builder": "@angular-devkit/build-angular:extract-i18n"
        },
        "test": {
          "builder": "@angular-devkit/build-angular:karma",
          "options": {
            "polyfills": [
              "zone.js",
              "zone.js/testing"
            ],
            "tsConfig": "projects/storefront/tsconfig.spec.json",
            "assets": [
              {
                "glob": "**/*",
                "input": "projects/storefront/public"
              },
              {
                "glob": "**/*",
                "input": "projects/shared-i18n/src/lib/assets/i18n",
                "output": "/assets/i18n"
              }
            ],
            "styles": [
              "projects/storefront/src/styles.css",
              "node_modules/leaflet/dist/leaflet.css"
            ],
            "scripts": []
          }
        },
        "lint": {
          "builder": "@angular-eslint/builder:lint",
          "options": {
            "lintFilePatterns": [
              "projects/storefront/**/*.ts",
              "projects/storefront/**/*.html"
            ]
          }
        }
      }
    },
    "dashboard": {
      "projectType": "application",
      "schematics": {},
      "root": "projects/dashboard",
      "sourceRoot": "projects/dashboard/src",
      "prefix": "db",
      "architect": {
        "build": {
          "builder": "@angular-devkit/build-angular:application",
          "options": {
            "outputPath": "dist/dashboard",
            "index": "projects/dashboard/src/index.html",
            "browser": "projects/dashboard/src/main.ts",
            "polyfills": [
              "zone.js"
            ],
            "tsConfig": "projects/dashboard/tsconfig.app.json",
            "assets": [
              {
                "glob": "**/*",
                "input": "projects/dashboard/public"
              },
              {
                "glob": "**/*",
                "input": "projects/shared-i18n/src/lib/assets/i18n",
                "output": "/assets/i18n"
              }
            ],
            "styles": [
              "projects/dashboard/src/styles.css"
            ],
            "scripts": []
          },
          "configurations": {
            "production": {
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "1mb",
                  "maximumError": "2mb"
                },
                {
                  "type": "anyComponentStyle",
                  "maximumWarning": "16kb",
                  "maximumError": "24kb"
                }
              ],
              "fileReplacements": [
                {
                  "replace": "projects/dashboard/src/environments/environment.ts",
                  "with": "projects/dashboard/src/environments/environment.prod.ts"
                }
              ],
              "outputHashing": "all"
            },
            "development": {
              "optimization": false,
              "extractLicenses": false,
              "sourceMap": true
            }
          },
          "defaultConfiguration": "production"
        },
        "serve": {
          "builder": "@angular-devkit/build-angular:dev-server",
          "configurations": {
            "production": {
              "buildTarget": "dashboard:build:production"
            },
            "development": {
              "buildTarget": "dashboard:build:development"
            }
          },
          "defaultConfiguration": "development",
          "options": {
            "proxyConfig": "projects/dashboard/proxy.conf.json"
          }
        },
        "test": {
          "builder": "@angular-devkit/build-angular:karma",
          "options": {
            "polyfills": [
              "zone.js",
              "zone.js/testing"
            ],
            "tsConfig": "projects/dashboard/tsconfig.spec.json",
            "assets": [
              {
                "glob": "**/*",
                "input": "projects/dashboard/public"
              },
              {
                "glob": "**/*",
                "input": "projects/shared-i18n/src/lib/assets/i18n",
                "output": "/assets/i18n"
              }
            ],
            "styles": [
              "projects/dashboard/src/styles.css"
            ],
            "scripts": []
          }
        },
        "lint": {
          "builder": "@angular-eslint/builder:lint",
          "options": {
            "lintFilePatterns": [
              "projects/dashboard/**/*.ts",
              "projects/dashboard/**/*.html"
            ]
          }
        }
      }
    },
    "shared-ui": {
      "projectType": "library",
      "root": "projects/shared-ui",
      "sourceRoot": "projects/shared-ui/src",
      "prefix": "ui",
      "architect": {
        "build": {
          "builder": "@angular-devkit/build-angular:ng-packagr",
          "options": {
            "project": "projects/shared-ui/ng-package.json"
          },
          "configurations": {
            "production": {
              "tsConfig": "projects/shared-ui/tsconfig.lib.prod.json"
            },
            "development": {
              "tsConfig": "projects/shared-ui/tsconfig.lib.json"
            }
          },
          "defaultConfiguration": "production"
        },
        "test": {
          "builder": "@angular-devkit/build-angular:karma",
          "options": {
            "tsConfig": "projects/shared-ui/tsconfig.spec.json",
            "polyfills": [
              "zone.js",
              "zone.js/testing"
            ]
          }
        },
        "lint": {
          "builder": "@angular-eslint/builder:lint",
          "options": {
            "lintFilePatterns": [
              "projects/shared-ui/**/*.ts",
              "projects/shared-ui/**/*.html"
            ]
          }
        }
      }
    },
    "shared-api": {
      "projectType": "library",
      "root": "projects/shared-api",
      "sourceRoot": "projects/shared-api/src",
      "prefix": "api",
      "architect": {
        "build": {
          "builder": "@angular-devkit/build-angular:ng-packagr",
          "options": {
            "project": "projects/shared-api/ng-package.json"
          },
          "configurations": {
            "production": {
              "tsConfig": "projects/shared-api/tsconfig.lib.prod.json"
            },
            "development": {
              "tsConfig": "projects/shared-api/tsconfig.lib.json"
            }
          },
          "defaultConfiguration": "production"
        },
        "test": {
          "builder": "@angular-devkit/build-angular:karma",
          "options": {
            "tsConfig": "projects/shared-api/tsconfig.spec.json",
            "polyfills": [
              "zone.js",
              "zone.js/testing"
            ]
          }
        },
        "lint": {
          "builder": "@angular-eslint/builder:lint",
          "options": {
            "lintFilePatterns": [
              "projects/shared-api/**/*.ts",
              "projects/shared-api/**/*.html"
            ]
          }
        }
      }
    },
    "shared-i18n": {
      "projectType": "library",
      "root": "projects/shared-i18n",
      "sourceRoot": "projects/shared-i18n/src",
      "prefix": "i18n",
      "architect": {
        "build": {
          "builder": "@angular-devkit/build-angular:ng-packagr",
          "options": {
            "project": "projects/shared-i18n/ng-package.json"
          },
          "configurations": {
            "production": {
              "tsConfig": "projects/shared-i18n/tsconfig.lib.prod.json"
            },
            "development": {
              "tsConfig": "projects/shared-i18n/tsconfig.lib.json"
            }
          },
          "defaultConfiguration": "production"
        },
        "test": {
          "builder": "@angular-devkit/build-angular:karma",
          "options": {
            "tsConfig": "projects/shared-i18n/tsconfig.spec.json",
            "polyfills": [
              "zone.js",
              "zone.js/testing"
            ]
          }
        },
        "lint": {
          "builder": "@angular-eslint/builder:lint",
          "options": {
            "lintFilePatterns": [
              "projects/shared-i18n/**/*.ts",
              "projects/shared-i18n/**/*.html"
            ]
          }
        }
      }
    }
  }
}