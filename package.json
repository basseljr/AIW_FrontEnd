{
  "name": "aiw-frontend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "ng": "ng",
    "start": "ng serve storefront",
    "start:dashboard": "ng serve dashboard",
    "start:super-admin": "ng serve super-admin",
    "build": "ng build storefront --configuration=development && ng build dashboard --configuration=development && ng build super-admin --configuration=development",
    "build:prod": "ng build storefront --configuration=production && ng build dashboard --configuration=production && ng build super-admin --configuration=production",
    "build:storefront": "ng build storefront",
    "build:dashboard": "ng build dashboard",
    "build:super-admin": "ng build super-admin",
    "test": "ng test storefront --watch=false --browsers=ChromeHeadless && ng test dashboard --watch=false --browsers=ChromeHeadless && ng test super-admin --watch=false --browsers=ChromeHeadless && ng test shared-ui --watch=false --browsers=ChromeHeadless && ng test shared-api --watch=false --browsers=ChromeHeadless && ng test shared-i18n --watch=false --browsers=ChromeHeadless",
    "test:storefront": "ng test storefront --watch=false --browsers=ChromeHeadless",
    "test:dashboard": "ng test dashboard --watch=false --browsers=ChromeHeadless",
    "test:super-admin": "ng test super-admin --watch=false --browsers=ChromeHeadless",
    "test:libs": "ng test shared-ui --watch=false --browsers=ChromeHeadless && ng test shared-api --watch=false --browsers=ChromeHeadless && ng test shared-i18n --watch=false --browsers=ChromeHeadless",
    "lint": "ng lint",
    "format": "prettier --write \"**/*.{ts,html,css,scss,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,html,css,scss,json,md}\"",
    "i18n:check": "node scripts/check-translations.js"
  },
